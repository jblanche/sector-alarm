{
  "name": "@jonathanblanchet/sector-alarm",
  "version": "0.1.0",
  "description": "TypeScript client for the Sector Alarm API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.0.0",
    "typescript": "next",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
